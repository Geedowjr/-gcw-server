    "@types/nodemailer": "^6.4.15",
    "@types/pg": "^8.11.6",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^9.0.8",
    "drizzle-kit": "^0.20.17",
    "eslint": "^8.57.0",
    "pino-pretty": "^11.0.0",
